# ===== Runtime =====
CUDA_VISIBLE_DEVICES=0
HF_ENDPOINT=https://huggingface.co

# ===== Hugging Face auth/cache =====
# Required for gated models/datasets.
HF_TOKEN=
HF_HOME=.cache/huggingface
HF_DATASETS_CACHE=.cache/huggingface/datasets

# ===== Model =====
# Either a local path or a Hugging Face model id.
MODEL_PATH=Qwen/Qwen2.5-VL-7B-Instruct

# ===== vLLM / eval defaults =====
VLLM_TP=1
BATCH_SIZE=1
LIMIT=1
GPU_MEM_UTIL_PHASE1=0.45
MAX_MODEL_LEN_PHASE1=512
ENABLE_PHASE2=0
SLEEP_SECONDS=1

# ===== Optional API for MMBench judge =====
# OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# API_TYPE=openai
# MODEL_VERSION=gpt-4o-mini
